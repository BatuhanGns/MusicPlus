# ─────────────────────────────────────────────
# Music+ Ortam Değişkenleri
# Her değişkeni nasıl alacağını öğrenmek için:
# → docs/ENVIRONMENT.md
# ─────────────────────────────────────────────

# Flask — güvenli rastgele anahtar üret:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=buraya-guclu-rastgele-anahtar-yaz

# Spotify Developer Dashboard'dan al
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Google Cloud Service Account (Sheets API)
# https://console.cloud.google.com
GOOGLE_SHEETS_ID=
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── Opsiyonel ───────────────────────────────

# AI müzik asistanı için (opsiyonel)
# https://aistudio.google.com
GEMINI_API_KEY=
